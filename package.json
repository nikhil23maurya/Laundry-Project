{
  "name": "mini-laundry-oms",
  "version": "1.0.0",
  "description": "Mini Laundry Order Management System",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "server": "node index.js",
    "server:dev": "nodemon index.js",
    "client": "npm --prefix frontend run dev",
    "dev": "concurrently -n server,client -c blue,green \"npm run server:dev\" \"npm run client\"",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "sql.js": "^1.13.0",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10"
  }
}
